{
  "name": "pakalon",
  "version": "0.1.0",
  "description": "AI-powered CLI code editor that builds production software in 6 autonomous phases",
  "keywords": ["ai", "cli", "code-editor", "agentic", "pakalon", "openrouter", "langgraph"],
  "license": "MIT",
  "bin": {
    "pakalon": "./dist/index.js"
  },
  "files": [
    "dist/",
    "python/",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "build": "bun build src/index.tsx --target bun --outdir dist --minify --external react-devtools-core",
    "dev": "bun src/index.tsx",
    "start": "bun run dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts,.tsx",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "prepublishOnly": "bun run build && bun run type-check"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "@openrouter/ai-sdk-provider": "2.2.3",
    "@tanstack/react-query": "^5.0.0",
    "@types/eventsource": "^1.1.15",
    "@types/figlet": "^1.7.0",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/react": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/yargs": "^17.0.33",
    "ai": "6.0.91",
    "chalk": "^5.4.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.38.0",
    "eventsource": "^3.0.2",
    "figlet": "^1.8.0",
    "fluent-ffmpeg": "^2.1.3",
    "ink": "6.7.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "node-fetch": "^3.3.2",
    "open": "^10.1.0",
    "ora": "^8.1.1",
    "os": "^0.1.2",
    "react": "^19.0.0",
    "react-devtools-core": "^7.0.1",
    "sharp": "^0.33.5",
    "term-img": "^6.0.0",
    "uuid": "^11.1.0",
    "yargs": "^17.7.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "drizzle-kit": "^0.30.0",
    "@types/node": "^22.0.0",
    "bun-types": "^1.1.0",
    "eslint": "^9.20.0",
    "@typescript-eslint/eslint-plugin": "^8.24.0",
    "@typescript-eslint/parser": "^8.24.0",
    "prettier": "^3.4.0",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "axios": "^1.7.0"
  }
}
